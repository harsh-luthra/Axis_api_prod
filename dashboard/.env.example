# Browser-facing API URL — used by the production build
# Leave blank in dev so Vite's proxy is used instead
VITE_API_URL=

# Dev-only: target Vite forwards API calls to (defaults to http://localhost:3000)
API_PROXY_TARGET=http://localhost:3000

# Port the dashboard's own Express server listens on
PORT=3001

# Base path the SPA is served under. Must match `base` in vite.config.js
# and `basename` on the BrowserRouter. Defaults to /dashboard.
BASE_PATH=/dashboard
